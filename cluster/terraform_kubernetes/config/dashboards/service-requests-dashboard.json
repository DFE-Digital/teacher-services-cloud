        "showUnfilled": true,
        "text": {}
      },
      "repeat": "service",
      "repeatDirection": "v",
      "maxPerRow": 1,
      "pluginVersion": "9.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P5DCFC7561CCDE821"
          },
          "editorMode": "code",
          "expr": "sum(rate(nginx_ingress_controller_requests{service=\"$service\", status=~\"2..\"}[$__rate_interval]))",
