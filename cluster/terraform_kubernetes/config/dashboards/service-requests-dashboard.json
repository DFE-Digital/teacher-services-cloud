        {
          "datasource": {
            "type": "prometheus",
            "uid": "P5DCFC7561CCDE821"
          },
          "editorMode": "code",
          "expr": "sum(rate(nginx_ingress_controller_requests{service=\"$service\", status=~\"4..\"}[$__rate_interval]))",
          "legendFormat": "4xx",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "P5DCFC7561CCDE821"
          },
          "editorMode": "code",
          "expr": "sum(rate(nginx_ingress_controller_requests{service=\"$service\", status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx",
          "range": true,
          "refId": "C"
        }
      ],
