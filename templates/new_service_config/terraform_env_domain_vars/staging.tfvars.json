{
  "hosted_zone": {
    "#DNS_ZONE_NAME#": {
      "front_door_name": "#FRONT_DOOR_NAME#",
      "resource_group_name": "#DOMAINS_RESOURCE_GROUP_NAME#",
      "domains": [
        "staging"
      ],
      "cached_paths": [
        "/assets/*"
      ],
      "environment_short": "dv",
      "origin_hostname": "#SERVICE_NAME#-staging.test.teacherservices.cloud"
    }
  },
  "rate_limit_max": 300,
  "allow_aks": true,
  "block_ip": true
}
